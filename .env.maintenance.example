# Maintenance Mode Environment Variables
# Copy these to your .env file to override maintenance config

# Enable/disable maintenance mode
VITE_MAINTENANCE_ENABLED=false

# Customize maintenance messages
VITE_MAINTENANCE_TITLE="We'll be back soon!"
VITE_MAINTENANCE_MESSAGE="We're currently performing scheduled maintenance to improve your experience. Thank you for your patience."

# Estimated completion time (ISO 8601 format)
# Example: VITE_MAINTENANCE_COMPLETION=2024-03-30T14:00:00Z
VITE_MAINTENANCE_COMPLETION=

# Contact information
VITE_MAINTENANCE_CONTACT_EMAIL=support@deeptech.com
VITE_MAINTENANCE_CONTACT_PHONE=

# Social links
VITE_MAINTENANCE_TWITTER=https://twitter.com/deeptech
VITE_MAINTENANCE_LINKEDIN=https://linkedin.com/company/deeptech
VITE_MAINTENANCE_WEBSITE=https://deeptech.com

# User roles that can bypass maintenance (comma-separated)
VITE_MAINTENANCE_BYPASS_ROLES=admin

# Restricted routes during maintenance (comma-separated)
# Leave empty to restrict all routes
VITE_MAINTENANCE_RESTRICTED_ROUTES=